@dp.callback_query(F.data == "confirm_month")
async def cb_confirm_month(cb: types.CallbackQuery):
    await bot.send_invoice(
        chat_id=cb.from_user.id,
        title="🚀 VPN 1 месяц",
        description="200 ГБ трафика · 30 дней · VLESS Reality + Hysteria2",
        payload=f"vpn_month_{cb.from_user.id}",
        currency="XTR",
        prices=[LabeledPrice(label="VPN 1 месяц", amount=1)],
    )
    await cb.answer()

@dp.pre_checkout_query()
async def pre_checkout(q: PreCheckoutQuery):
    await q.answer(ok=True)

@dp.message(F.successful_payment)
async def on_payment(msg: Message):
    payload = msg.successful_payment.invoice_payload
    parts = payload.split("_")
    if len(parts) < 2 or parts[0] != "vpn":
        return
    plan_key = parts[1]
    plan = PLANS.get(plan_key)
    if not plan:
        return

    await msg.answer(
        f"⭐ <b>Оплата получена!</b>\n\n⏳ Активируем ваш VPN...",
        parse_mode="HTML"
    )

    tg_id = msg.from_user.id
    existing = await get_user_by_tg(tg_id)

    if existing:
        user = await extend_panel_user(existing["id"], plan_key)
        if not user or not user.get("id"):
            user = existing
    else:
        user = await create_panel_user(tg_id, plan_key)

    uid = (user or {}).get("id") or (existing or {}).get("id")
    if uid:
        keys = await api_get(f"/api/users/{uid}/keys") or []
        sub = (user or existing or {}).get("subscription_token", "")
        await msg.answer(
            txt_keys(user or existing, keys, sub, plan_key),
            reply_markup=kb_back(), parse_mode="HTML"
        )
    else:
        await msg.answer(
            "❌ <b>Ошибка активации.</b>\nНапишите в поддержку — платёж сохранён.",
            reply_markup=kb_back(), parse_mode="HTML"
        )

# ── MY VPN ──
@dp.callback_query(F.data == "my_vpn")
async def cb_my_vpn(cb: types.CallbackQuery):
    tg_id = cb.from_user.id
    user = await get_user_by_tg(tg_id)
    if not user:
        await cb.message.edit_text(
            f"🔍 <b>Аккаунт не найден</b>\n\nУ вас ещё нет VPN.\nВыберите тариф:",
            reply_markup=kb_no_vpn(), parse_mode="HTML"
        )
    else:
        expiry = user.get("expiry_date")
        status = user.get("status", "unknown")
        status_icon = "🟢" if status == "active" else "🔴"
        traffic_used = user.get("traffic_used", 0) or 0
        traffic_limit = user.get("traffic_limit", 0) or 0
        used_mb = round(traffic_used / (1024*1024), 1)
        used_gb = round(traffic_used / (1024**3), 2)
        used_str = f"{used_gb} ГБ" if traffic_used >= 1024**3 else f"{used_mb} МБ"
        if traffic_limit >= 1024**3:
            limit_str = f"{int(traffic_limit/(1024**3))} ГБ"
        elif traffic_limit > 0:
            limit_str = f"{int(traffic_limit/(1024*1024))} МБ"
        else:
            limit_str = "—"

        days_left = "♾️ Без срока"
        server_status = "🟢 Онлайн"
        if expiry:
            try:
                exp_date = datetime.strptime(expiry, "%Y-%m-%d")
                delta = (exp_date - datetime.now()).days
                days_left = f"<b>{delta} дней</b>" if delta > 0 else "❗ <b>Истёк</b>"
            except:
                days_left = expiry

        text = (
            f"👤 <b>Мой VPN</b>\n"
            f"{D}\n"
            f"{status_icon} Статус: <b>{status}</b>\n"
            f"🖥 Сервер: {server_status}\n"
            f"📅 Осталось: {days_left}\n"
            f"📊 Трафик: <b>{used_str} / {limit_str}</b>\n"
            f"{D}\n"
            f"🌍 Серверы: 🇷🇺 · 🇩🇪 · 🇫🇮"
        )
        await cb.message.edit_text(text, reply_markup=kb_my_vpn(), parse_mode="HTML")
    await cb.answer()

# ── MY KEYS ──
@dp.callback_query(F.data == "my_keys")
async def cb_my_keys(cb: types.CallbackQuery):
    tg_id = cb.from_user.id
    user = await get_user_by_tg(tg_id)
    if not user:
        await cb.answer("❌ Аккаунт не найден", show_alert=True)
        return
    keys = await api_get(f"/api/users/{user['id']}/keys") or []
    sub = user.get("subscription_token", "")
    # detect plan
    tl = user.get("traffic_limit", 0) or 0
    plan_key = "month" if tl >= 1024**3 else "trial"
    await cb.message.edit_text(
        txt_keys(user, keys, sub, plan_key),
        reply_markup=kb_back(), parse_mode="HTML"
    )
    await cb.answer()

