@dp.callback_query(F.data == "confirm_trial")
async def cb_confirm_trial(cb: types.CallbackQuery):
    await cb.answer()
    tg_id = cb.from_user.id
    existing = await get_user_by_tg(tg_id)
    if existing:
        await cb.message.edit_text(
            f"ℹ️ <b>У вас уже есть аккаунт!</b>\n\nИспользуйте <b>🔑 Мой VPN</b> для просмотра ключей.",
            reply_markup=kb_my_vpn(), parse_mode="HTML"
        )
        return
    user = await create_panel_user(tg_id, "trial")
    if user and user.get("id"):
        keys = await api_get(f"/api/users/{user['id']}/keys") or []
        sub = user.get("subscription_token", "")
        await cb.message.edit_text(
            txt_keys(user, keys, sub, "trial"),
            reply_markup=kb_back(), parse_mode="HTML"
        )
    else:
        await cb.message.edit_text(
            "❌ Ошибка создания аккаунта. Напишите в поддержку.",
            reply_markup=kb_back(), parse_mode="HTML"
        )

