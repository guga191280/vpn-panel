def txt_keys(user: dict, keys, sub_token: str, plan_key: str) -> str:
    plan = PLANS[plan_key]
    expiry = user.get("expiry_date")
    traffic_used = user.get("traffic_used", 0) or 0
    traffic_limit = user.get("traffic_limit", 0) or 0

    used_mb = round(traffic_used / (1024 * 1024), 1)
    used_gb = round(traffic_used / (1024 ** 3), 2)

    if traffic_limit >= 1024 ** 3:
        limit_str = f"{int(traffic_limit / (1024**3))} ГБ"
    elif traffic_limit > 0:
        limit_mb = round(traffic_limit / (1024 * 1024), 0)
        limit_str = f"{int(limit_mb)} МБ"
    else:
        limit_str = "—"

    used_str = f"{used_gb} ГБ" if traffic_used >= 1024**3 else f"{used_mb} МБ"

    # Days left
    days_left = "—"
    if expiry:
        try:
            exp_date = datetime.strptime(expiry, "%Y-%m-%d")
            delta = (exp_date - datetime.now()).days
            days_left = f"{delta} дней" if delta > 0 else "❗ Истёк"
        except:
            days_left = expiry
    else:
        days_left = "♾️ Без срока"

    lines = [
        f"✅ <b>VPN активирован!</b>",
        D,
        f"📅 Осталось: <b>{days_left}</b>",
        f"📦 Трафик: <b>{used_str} / {limit_str}</b>",
        D,
        f"🔑 <b>Ваши ключи:</b>",
        "",
    ]

    if keys:
        for k in keys:
            srv = k.get("server", "")
            flag = "🇷🇺" if ("russia" in srv or "212.15" in srv) else \
                   "🇩🇪" if "de" in srv else \
                   "🇫🇮" if "fin" in srv else "🌍"
            proto = k.get("protocol", "vless").upper()
            key_str = k.get("key", "—")
            lines += [
                f"{flag} <b>{proto}</b>",
                f"<code>{key_str}</code>",
                "",
            ]
    else:
        lines += ["⚠️ Ключи генерируются, подождите 1 минуту.", ""]

    if sub_token:
        lines += [
            D2,
            f"🔗 <b>Ссылка-подписка:</b>",
            f"<code>{PANEL_URL}/sub/{sub_token}</code>",
            "",
        ]

    lines += [
        D2,
        f"📱 Android/iOS: <b>Happ VPN · Hiddify · v2Tun · v2Box</b>",
        f"💻 PC: <b>Hiddify Next</b>",
    ]

    return "\n".join(lines)

